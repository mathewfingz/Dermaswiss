    "story_intro": {
      "type": "custom-html",
      "settings": {
        "container": "container",
        "color_schema": "",
        "heading": "",
        "heading_size": "h-xl",
        "heading_color": "",
        "subheading": "",
        "description": "",
        "custom_html": "<style>\n  .story-intro {\n    max-width: 720px;\n    margin: 0 auto;\n    text-align: center;\n    padding: 80px 24px;\n  }\n  .story-intro__icon {\n    width: 48px;\n    height: 1px;\n    background: #B7002C;\n    margin: 0 auto 32px;\n  }\n  .story-intro__heading {\n    font-size: clamp(24px, 3vw, 36px);\n    font-weight: 300;\n    letter-spacing: 1px;\n    color: #222;\n    line-height: 1.4;\n    margin-bottom: 24px;\n    font-family: serif;\n  }\n  .story-intro__text {\n    font-size: 15px;\n    font-weight: 300;\n    line-height: 2;\n    color: #666;\n  }\n  .story-intro__text em {\n    font-style: italic;\n    color: #B7002C;\n  }\n</style>\n<div class=\"story-intro\">\n  <div class=\"story-intro__icon\"></div>\n  <h2 class=\"story-intro__heading\">Our Philosophy</h2>\n  <p class=\"story-intro__text\">Since 1992, DERMASWISS has developed skincare with purpose. Our mission is to simplify high-performance skincare for real people — at home and in the treatment room.<br><br>We believe in <em>Skin Knowledge</em> — understanding what your skin needs, and when. That's why every product is multifunctional, minimal, and rooted in science. Clean formulas powered by peptides, hyaluronic acid, ceramides, antioxidants, and Swiss Alpine botanicals.</p>\n</div>",
        "padding_top": 0,
        "padding_bottom": 0,
        "show_section_divider": false,
        "divider_width": "container",
        "custom_id": "",
        "custom_class": "",
        "animations": "inherit"
      }
    },
    "timeline_section": {
      "type": "custom-html",
      "settings": {
        "container": "container",
        "color_schema": "",
        "heading": "",
        "heading_size": "h-xl",
        "heading_color": "",
        "subheading": "",
        "description": "",
        "custom_html": "<style>\n  .tl-section { padding: 60px 24px 80px; }\n  .tl-section__title {\n    text-align: center;\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    color: #B7002C;\n    margin-bottom: 60px;\n  }\n  .tl {\n    position: relative;\n    max-width: 800px;\n    margin: 0 auto;\n    padding-left: 40px;\n  }\n  .tl::before {\n    content: '';\n    position: absolute;\n    top: 0;\n    left: 12px;\n    width: 1px;\n    height: 100%;\n    background: linear-gradient(to bottom, #B7002C, #e8e0d8, #B7002C);\n  }\n  .tl__item {\n    position: relative;\n    padding-bottom: 48px;\n    opacity: 0;\n    transform: translateY(20px);\n    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);\n  }\n  .tl__item.is-visible {\n    opacity: 1;\n    transform: translateY(0);\n  }\n  .tl__dot {\n    position: absolute;\n    left: -34px;\n    top: 4px;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    background: #fff;\n    border: 2px solid #B7002C;\n    z-index: 2;\n  }\n  .tl__year {\n    font-size: 13px;\n    font-weight: 700;\n    letter-spacing: 3px;\n    color: #B7002C;\n    margin-bottom: 6px;\n  }\n  .tl__title {\n    font-size: 20px;\n    font-weight: 400;\n    color: #222;\n    margin-bottom: 8px;\n    font-family: serif;\n  }\n  .tl__text {\n    font-size: 14px;\n    font-weight: 300;\n    line-height: 1.8;\n    color: #888;\n  }\n  @media (max-width: 749px) {\n    .tl { padding-left: 32px; }\n    .tl::before { left: 8px; }\n    .tl__dot { left: -30px; width: 10px; height: 10px; }\n  }\n</style>\n<div class=\"tl-section\">\n  <p class=\"tl-section__title\">Our Journey</p>\n  <div class=\"tl\">\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">1992</div>\n      <div class=\"tl__title\">The Beginning</div>\n      <p class=\"tl__text\">DERMASWISS is founded in Miami, Florida as Derma Swiss 3000 Manufacturers, Inc. Inspired by Swiss precision and cosmetic science traditions, the brand sets out to create clinical-grade skincare rooted in nature and innovation.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">1990s</div>\n      <div class=\"tl__title\">Building the Foundation</div>\n      <p class=\"tl__text\">The first formulations are developed using Swiss Alpine ingredients — plant derivatives, stem cells, and advanced peptide technology. Dermaswiss builds a reputation among estheticians and skin professionals in South Florida.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">2000s</div>\n      <div class=\"tl__title\">Professional Line Launch</div>\n      <p class=\"tl__text\">DERMASWISS Professional is born — a dedicated line for licensed estheticians. The brand introduces nanosphere delivery systems, bio-serums, and the Skin Knowledge philosophy that would become their signature.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">2010s</div>\n      <div class=\"tl__title\">Education Becomes Core</div>\n      <p class=\"tl__text\">DermaSwiss Institute opens as a licensed esthetics education school in Doral, FL. The brand's commitment to education deepens with on-demand seminars, professional training, and a complete facial specialist program.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">2020</div>\n      <div class=\"tl__title\">International Expansion</div>\n      <p class=\"tl__text\">Dermaswiss expands to Colombia and Latin America. The brand launches Spanish-language platforms and begins serving a growing community of professionals across the Americas.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">2024</div>\n      <div class=\"tl__title\">Digital Transformation</div>\n      <p class=\"tl__text\">Three distinct platforms launch: dermaswiss.com for consumers, dermaswisspro.com for professionals, and dermaswissinstitute.com for education. A unified digital ecosystem for the modern skincare professional.</p>\n    </div>\n    <div class=\"tl__item\">\n      <div class=\"tl__dot\"></div>\n      <div class=\"tl__year\">2026</div>\n      <div class=\"tl__title\">30+ Years and Growing</div>\n      <p class=\"tl__text\">With over three decades of expertise, 50+ products, and thousands of professionals trained, DERMASWISS continues to lead with science, integrity, and the belief that beautiful skin is possible at any age.</p>\n    </div>\n  </div>\n</div>\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    const items = document.querySelectorAll('.tl__item');\n    const observer = new IntersectionObserver(function(entries) {\n      entries.forEach(function(entry) {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { threshold: 0.15, rootMargin: '0px 0px -30px 0px' });\n    items.forEach(function(item, i) {\n      item.style.transitionDelay = (i * 0.1) + 's';\n      observer.observe(item);\n    });\n  });\n</script>",
