        "heading_color": "",
        "subheading": "",
        "description": "",
        "custom_html": "<style>\n  .values {\n    padding: 80px 24px;\n    max-width: 720px;\n    margin: 0 auto;\n    text-align: center;\n  }\n  .values__title {\n    font-size: 13px;\n    font-weight: 600;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    color: #B7002C;\n    margin-bottom: 40px;\n  }\n  .values__list {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 20px;\n  }\n  .values__item {\n    font-size: 16px;\n    font-weight: 300;\n    color: #555;\n    line-height: 1.6;\n    padding-bottom: 20px;\n    border-bottom: 1px solid #eee;\n  }\n  .values__item strong {\n    color: #222;\n    font-weight: 500;\n  }\n  .values__quote {\n    font-size: clamp(20px, 3vw, 28px);\n    font-weight: 300;\n    font-style: italic;\n    color: #222;\n    line-height: 1.5;\n    margin-top: 48px;\n    font-family: serif;\n  }\n  .values__quote-author {\n    font-size: 13px;\n    font-weight: 500;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #B7002C;\n    margin-top: 16px;\n  }\n</style>\n<div class=\"values\">\n  <p class=\"values__title\">What We Believe</p>\n  <ul class=\"values__list\">\n    <li class=\"values__item\"><strong>Effective from the first use</strong> — visible results from day one</li>\n    <li class=\"values__item\"><strong>Safe for all skin types</strong> and all ages</li>\n    <li class=\"values__item\"><strong>Powered by science,</strong> nature, and innovation</li>\n    <li class=\"values__item\"><strong>Clean & cruelty-free</strong> — paraben-free formulas</li>\n    <li class=\"values__item\"><strong>Education over trends</strong> — rooted in Skin Knowledge</li>\n  </ul>\n  <p class=\"values__quote\">\"Above all, the gift of looking beautiful at any age.\"</p>\n  <p class=\"values__quote-author\">— Dermaswiss</p>\n</div>",
