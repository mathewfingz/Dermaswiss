        "heading_color": "",
        "subheading": "",
        "description": "",
        "custom_html": "<style>\n  .stats {\n    padding: 80px 24px;\n    background: #0a0a0a;\n  }\n  .stats__grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 24px;\n    max-width: 900px;\n    margin: 0 auto;\n    text-align: center;\n  }\n  .stat__number {\n    font-size: clamp(36px, 5vw, 52px);\n    font-weight: 200;\n    color: #B7002C;\n    line-height: 1;\n    margin-bottom: 8px;\n    font-family: serif;\n  }\n  .stat__label {\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(255,255,255,0.5);\n  }\n  @media (max-width: 749px) {\n    .stats__grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }\n  }\n</style>\n<div class=\"stats\">\n  <div class=\"stats__grid\">\n    <div>\n      <div class=\"stat__number\">30+</div>\n      <div class=\"stat__label\">Years</div>\n    </div>\n    <div>\n      <div class=\"stat__number\">50+</div>\n      <div class=\"stat__label\">Products</div>\n    </div>\n    <div>\n      <div class=\"stat__number\">3</div>\n      <div class=\"stat__label\">Divisions</div>\n    </div>\n    <div>\n      <div class=\"stat__number\">1000s</div>\n      <div class=\"stat__label\">Professionals Trained</div>\n    </div>\n  </div>\n</div>",
