        "custom_html": "<style>\n  .since-cta {\n    padding: 80px 24px;\n    background: linear-gradient(135deg, #0a0a0a 0%, #1a1215 100%);\n    text-align: center;\n  }\n  .since-cta__heading {\n    font-size: clamp(24px, 3vw, 36px);\n    font-weight: 300;\n    color: #fff;\n    letter-spacing: 1px;\n    margin-bottom: 12px;\n    font-family: serif;\n  }\n  .since-cta__sub {\n    font-size: 15px;\n    color: rgba(255,255,255,0.5);\n    margin-bottom: 32px;\n  }\n  .since-cta__buttons {\n    display: flex;\n    gap: 16px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n  .since-cta__btn {\n    display: inline-flex;\n    align-items: center;\n    padding: 14px 36px;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    text-decoration: none;\n    transition: all 0.3s ease;\n  }\n  .since-cta__btn--primary {\n    background: #B7002C;\n    color: #fff;\n    border: 1px solid #B7002C;\n  }\n  .since-cta__btn--primary:hover {\n    background: #9A0024;\n    border-color: #9A0024;\n  }\n  .since-cta__btn--outline {\n    background: transparent;\n    color: #fff;\n    border: 1px solid rgba(255,255,255,0.2);\n  }\n  .since-cta__btn--outline:hover {\n    border-color: #fff;\n    background: rgba(255,255,255,0.04);\n  }\n</style>\n<div class=\"since-cta\">\n  <h2 class=\"since-cta__heading\">The Story Continues</h2>\n  <p class=\"since-cta__sub\">Join thousands of professionals who trust Dermaswiss.</p>\n  <div class=\"since-cta__buttons\">\n    <a href=\"/collections/all\" class=\"since-cta__btn since-cta__btn--primary\">Shop Products</a>\n    <a href=\"https://www.education.dermaswiss.com\" class=\"since-cta__btn since-cta__btn--outline\">Explore Education</a>\n    <a href=\"/pages/registerform\" class=\"since-cta__btn since-cta__btn--outline\">Become a Professional</a>\n  </div>\n</div>",
